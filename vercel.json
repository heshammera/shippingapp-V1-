{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "build": {
        "env": {
            "APP_ENV": "production",
            "COMPOSER_NO_DEV": "1"
        }
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "maxDuration": 30,
            "excludeFiles": "{tests/**,vendor/**/{[tT]ests,doc*}/**,storage/**,vendor/composer/{*.zip,tmp-*},vendor/mpdf/**/ttfonts/{[!D]*,D[!e]*,De[!j]*,DejaVu[!S]*,DejaVuSans[!.]*},vendor/dompdf/**/fonts/[!D]*,vendor/google/apiclient-services/src/[!DS]*/**}",
            "includeFiles": "{vendor,bootstrap,app,config,database,resources,routes,storage}/**"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/storage/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt"
        },
        {
            "src": "/livewire/livewire.js",
            "dest": "/api/index.php"
        },
        {
            "src": "/(.*\\.(css|js|json|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://${VERCEL_URL}",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "database",
        "SESSION_LIFETIME": "120",
        "SESSION_SECURE_COOKIE": "false",
        "SESSION_SAME_SITE": "lax"
    }
}