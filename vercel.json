{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "build": {
        "env": {
            "APP_ENV": "production",
            "COMPOSER_NO_DEV": "1"
        }
    },
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "maxDuration": 30,
            "excludeFiles": "{tests/**,vendor/**/{tests,Tests,test,Test}/**,vendor/**/{docs,doc,Docs,Doc}/**,vendor/**/{.git,.github}/**,vendor/**/{CHANGELOG,CHANGELOG.md,CHANGES.md,UPGRADING.md,UPGRADE.md,README.md,readme.md,LICENSE,LICENSE.md,license.md,CONTRIBUTING.md,.travis.yml,.scrutinizer.yml,phpunit.xml,phpunit.xml.dist,phpstan.neon,phpstan.neon.dist,.php_cs,.php_cs.dist,.editorconfig,.styleci.yml}*,storage/{logs,framework/cache,framework/sessions,framework/testing}/**,vendor/google/apiclient-services/src/[!DS]*/**,vendor/google/apiclient-services/src/D[!r]*/**,vendor/google/apiclient-services/src/S[!h]*/**,vendor/mpdf/mpdf/ttfonts/[!D]*,vendor/mpdf/mpdf/ttfonts/D[!e]*,vendor/mpdf/mpdf/data/codepages/**,vendor/dompdf/dompdf/lib/fonts/[!D]*,vendor/dompdf/dompdf/lib/fonts/D[!e]*,vendor/phpoffice/**/samples/**,vendor/phpseclib/**/{Functional,Unit}/**,vendor/nesbot/carbon/src/Carbon/Lang/[!e]*}",
            "includeFiles": "{vendor,bootstrap,app,config,database,resources,routes,storage}/**"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/storage/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/robots.txt"
        },
        {
            "src": "/livewire/livewire.js",
            "dest": "/api/index.php"
        },
        {
            "src": "/(.*\\.(css|js|json|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://${VERCEL_URL}",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "database",
        "SESSION_LIFETIME": "120",
        "SESSION_SECURE_COOKIE": "false",
        "SESSION_SAME_SITE": "lax"
    }
}